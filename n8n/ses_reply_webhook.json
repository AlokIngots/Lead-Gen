{
  "name": "Alok LMS — SES Reply Tracking",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "ses-reply",
        "responseMode": "lastNode",
        "options": { "responseData": "allEntries" }
      },
      "id": "webhook-trigger",
      "name": "POST /webhook/ses-reply",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "ses-reply"
    },
    {
      "parameters": {
        "jsCode": "// Parse the SNS notification — supports raw SES payload or SNS-wrapped\nconst body = $input.first().json.body || $input.first().json;\n\nlet message = body;\nif (typeof body.Message === 'string') {\n  try { message = JSON.parse(body.Message); } catch (e) { /* keep body */ }\n} else if (body.Message) {\n  message = body.Message;\n}\n\nconst mail = message.mail || {};\n// SES inbound: source = the sender (the lead replying)\nlet email = mail.source || (mail.commonHeaders && mail.commonHeaders.from && mail.commonHeaders.from[0]);\nif (Array.isArray(email)) email = email[0];\nif (email && email.includes('<')) {\n  const m = email.match(/<([^>]+)>/);\n  if (m) email = m[1];\n}\n\nconst subject = (mail.commonHeaders && mail.commonHeaders.subject) || message.subject || null;\n\nreturn [{ json: { email: (email || '').toLowerCase().trim(), subject, raw_message_id: mail.messageId || null } }];"
      },
      "id": "parse-sns",
      "name": "Parse SES/SNS body",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "url": "={{$env.LMS_API_URL}}/leads",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "q", "value": "={{$json.email}}" },
            { "name": "page_size", "value": "1" }
          ]
        },
        "options": { "timeout": 15000 }
      },
      "id": "find-lead",
      "name": "GET /leads?q=email",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [680, 300],
      "credentials": {
        "httpHeaderAuth": { "id": "lms-bearer", "name": "LMS Bearer" }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose" },
          "conditions": [
            { "id": "found", "leftValue": "={{$json.total}}", "rightValue": 0, "operator": { "type": "number", "operation": "gt" } }
          ],
          "combinator": "and"
        }
      },
      "id": "if-found",
      "name": "Lead found?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [900, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.LMS_API_URL}}/events",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"lead_id\": {{$json.items[0].id}},\n  \"channel\": \"email\",\n  \"event_type\": \"replied\",\n  \"score_delta\": 30,\n  \"notes\": \"Email reply received via SES\"\n}",
        "options": { "timeout": 15000 }
      },
      "id": "log-reply",
      "name": "POST /events replied",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1140, 220],
      "credentials": {
        "httpHeaderAuth": { "id": "lms-bearer", "name": "LMS Bearer" }
      }
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "={{$env.LMS_API_URL}}/leads/{{$json.items[0].id}}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"status\": \"engaged\" }",
        "options": { "timeout": 15000 }
      },
      "id": "patch-lead",
      "name": "PATCH lead → engaged",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
