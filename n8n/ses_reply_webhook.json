        "queryParameters": {
          "parameters": [
            { "name": "role", "value": "sc" }
          ]
        },
        "options": { "timeout": 15000 }
      },
      "id": "fetch-scs",
      "name": "GET /users role=sc",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1800, 220],
      "credentials": {
