      "credentials": {
        "httpHeaderAuth": { "id": "lms-bearer", "name": "LMS Bearer" }
      }
    },
    {
      "parameters": {
        "url": "={{$env.LMS_API_URL}}/leads/{{$json.items[0].id}}",
        "options": { "timeout": 15000 }
      },
      "id": "fetch-lead",
      "name": "GET lead (for SC info)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1580, 220],
      "credentials": {
