    {
      "parameters": {
        "method": "POST",
        "url": "https://api.interakt.ai/v1/public/message/",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "Basic {{$env.INTERAKT_API_KEY}}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"countryCode\": \"+91\",\n  \"phoneNumber\": \"{{ ($json.find(u => u.emp_code === $('GET lead (for SC info)').item.json.assigned_sc) || {}).phone || '' }}\",\n  \"type\": \"Text\",\n  \"data\": {\n    \"message\": \"Reply received from {{$('GET lead (for SC info)').item.json.company_name}} ({{$('GET lead (for SC info)').item.json.email}}). Log in to LMS to follow up: https://lms.alokindia.co.in/leads/{{$('GET lead (for SC info)').item.json.id}}\"\n  }\n}",
        "options": { "timeout": 30000 }
      },
      "id": "notify-sc",
      "name": "Interakt — Notify SC",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2020, 220]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"ok\": true }"
      },
      "id": "ok-found",
