DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=alok_lms
DB_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
DB_NAME=alok_lms
SECRET_KEY=CHANGE_ME_USE_STRONG_SECRET
CORS_ORIGINS=http://localhost:5173,https://lms.alokindia.co.in

# Auth — JWT_SECRET_KEY MUST be at least 32 chars. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_COMMAND_ABOVE
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=2

# OTP delivery: mock (dev), interakt, interakt_then_sms, or live
SMS_MODE=mock
# NEVER set DEV_RETURN_OTP=true in production
DEV_RETURN_OTP=false
INTERAKT_COUNTRY_CODE=+91
# INTERAKT_API_KEY=
# INTERAKT_OTP_TEMPLATE_NAME=login_otp
# INTERAKT_TEMPLATE_LANGUAGE=en

OTP_MAX_ATTEMPTS=5
OTP_WINDOW_SECONDS=300
OTP_VERIFY_MAX_ATTEMPTS=5
OTP_VERIFY_WINDOW_SECONDS=300

# API key for n8n/webhook callers (drip endpoints). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
DRIP_API_KEY=CHANGE_ME_GENERATE_WITH_COMMAND_ABOVE
